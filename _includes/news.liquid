<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    {% if include.limit and page.announcements.limit %}
      {% assign news_limit = page.announcements.limit %}
    {% else %}
      {% assign news_limit = news_size %}
    {% endif %}
    <div
      class="table-responsive{% if include.limit and page.announcements.scrollable and news_size > news_limit %} news-scroll-frame{% endif %}"
      {% if include.limit and page.announcements.scrollable and news_size > news_limit %}
        style="max-height: 24rem"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign news = site.news | reverse %}
        {% if include.limit and page.announcements.scrollable %}
          {% assign render_limit = news_size %}
        {% else %}
          {% assign render_limit = news_limit %}
        {% endif %}
        {% for item in news limit: render_limit %}
          <tr>
            <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
            <td>
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
