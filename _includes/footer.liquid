{% capture footer_contents %}
  {{ site.footer_text }}
  {% if site.last_updated %}
    Last updated: {{ 'now' | date: '%B %d, %Y' }}.
  {% endif %}
{% endcapture %}

{% if site.footer_fixed %}
  <footer class="fixed-bottom" role="contentinfo">
    <div class="container footer-shell mt-0">
      <div class="footer-identity">
        <span class="footer-name">{{ site.first_name }} {{ site.last_name }}</span>
        <p class="footer-tagline">AI for chemistry, retrosynthesis, and scientific machine learning.</p>
      </div>
      <div class="footer-meta">
        <span>{{ footer_contents }}</span>
        {% if site.impressum_path %}
          <a href="{{ site.url }}{{ site.baseurl }}{{ site.impressum_path }}">Impressum</a>.
        {% endif %}
      </div>
    </div>
  </footer>
{% else %}
  <footer class="sticky-bottom mt-5" role="contentinfo">
    {% if site.newsletter.enabled %}
      {% include newsletter.liquid %}
    {% endif %}

    <div class="container footer-shell">
      <div class="footer-identity">
        <span class="footer-name">{{ site.first_name }} {{ site.last_name }}</span>
        <p class="footer-tagline">AI for chemistry, retrosynthesis, and scientific machine learning.</p>
      </div>
      <div class="footer-meta">
        <span>{{ footer_contents }}</span>
        {% if site.impressum_path %}
          <a href="{{ site.url }}{{ site.baseurl }}{{ site.impressum_path }}">Impressum</a>.
        {% endif %}
      </div>
    </div>
  </footer>
{% endif %}
